(
rm(list = setdiff(ls(all.names = TRUE), c("all_sig_df", "clumped_df")))
#  Load the data
all_sig_path <- "/Users/sezgi/Documents/dominance_pleiotropy/SNP_level/significant_SNPs/all_sig_SNPs.tsv.gz"
all_sig_df <- fread(all_sig_path, select = c("variant", "rsid", "chr", "pos", "minor_AF", "info", "p_hwe", "add_sig_total",
"dom_sig_total", "over_dom_sig_total", "sig_add_traits", "sig_dom_traits",
"sig_over_dom_traits", "add_betas", "dom_betas", "over_dom_betas",
"add_pvals", "dom_pvals", "over_dom_pvals"))
dom_sig <- all_sig_df %>%
filter(dom_sig_total > 0)
all_dom_betas <- dom_sig$dom_betas %>%
map(~ fromJSON(.x)) %>%
flatten_dbl()
all_dom_betas <- dom_sig$dom_betas %>%
map(function(x) {
# Replace double-double quotes with a single double quote
clean_json <- gsub('""', '"', x)
# Parse the cleaned string
# Since this is a key-value pair (Dictionary/List), we take the values
fromJSON(clean_json) %>% unlist()
}) %>%
flatten_dbl()
# 2. Create a data frame for plotting
plot_data <- data.frame(beta = all_dom_betas)
# 3. Generate the Nature Genetics-style plot
ggplot(plot_data, aes(x = beta)) +
# Using a semi-transparent fill and a subtle outline
geom_histogram(aes(y = ..density..),
bins = 50,
fill = "#377EB8",
color = "white",
size = 0.2) +
geom_density(color = "black", size = 0.5) +
# Nature Genetics typically uses Arial/Helvetica and specific font sizes
theme_bw() +
theme(
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
axis.title = element_text(size = 8, family = "Helvetica", face = "plain"),
axis.text = element_text(size = 7, family = "Helvetica"),
axis.line = element_line(size = 0.3, color = "black"),
panel.border = element_blank(),
strip.background = element_blank()
) +
labs(
x = expression(paste("Dominance Effect Size (", beta, ")")),
y = "Density"
)
View(plot_data)
max(plot_data$beta)
dom_over <- all_sig_df %>%
filter(over_dom_sig_total > 0)
all_dom_betas <- dom_over$dom_betas %>%
map(function(x) {
# Replace double-double quotes with a single double quote
clean_json <- gsub('""', '"', x)
# Parse the cleaned string
# Since this is a key-value pair (Dictionary/List), we take the values
fromJSON(clean_json) %>% unlist()
}) %>%
flatten_dbl()
# 2. Create a data frame for plotting
plot_data <- data.frame(beta = all_dom_betas)
# 3. Generate the Nature Genetics-style plot
ggplot(plot_data, aes(x = beta)) +
# Using a semi-transparent fill and a subtle outline
geom_histogram(aes(y = ..density..),
bins = 50,
fill = "#377EB8",
color = "white",
size = 0.2) +
geom_density(color = "black", size = 0.5) +
# Nature Genetics typically uses Arial/Helvetica and specific font sizes
theme_bw() +
theme(
panel.grid.major = element_blank(),
panel.grid.minor = element_blank(),
axis.title = element_text(size = 8, family = "Helvetica", face = "plain"),
axis.text = element_text(size = 7, family = "Helvetica"),
axis.line = element_line(size = 0.3, color = "black"),
panel.border = element_blank(),
strip.background = element_blank()
) +
labs(
x = expression(paste("Dominance Effect Size (", beta, ")")),
y = "Density"
)
max(plot_data$beta)
min(plot_data$beta)
median(plot_data$beta)
quantile(plot_data$beta, 0.75)
quantile(plot_data$beta, 0.25)
max(plot_data$beta)
